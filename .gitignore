# ═══════════════════════════════════════════════════════════════════
#  .gitignore — Raiz do Monorepo (backend + frontend)
# ═══════════════════════════════════════════════════════════════════
#  Este arquivo fica na RAIZ do repositório e cobre ambos os projetos.
#  Cada subprojeto pode ter seu próprio .gitignore adicional para
#  regras específicas.

# ─── IDE ──────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo

# ─── OS ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Java / Maven (backend) ──────────────────────────────────────
*.class
*.jar
*.war
*.ear
/out/
*.log

# ─── Node.js / npm (frontend) ────────────────────────────────────
node_modules/
